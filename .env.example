# Groq API Key (for the Education Agent)
GROQ_API_KEY=your_groq_api_key_here

# API Server Configuration
HOST=0.0.0.0
PORT=8000

# API Key Security
# Set a random string to secure API key hashing.
# Example: API_KEY_PEPPER=$(openssl rand -hex 32)
API_KEY_PEPPER=

# Logging
LOG_FILE=./logs/server.log

# Agent Configuration
DEFAULT_EDUCATION_AGENT=phi-3

# Optional: Enable detailed logging
# VERBOSE_THIRD_PARTY=true